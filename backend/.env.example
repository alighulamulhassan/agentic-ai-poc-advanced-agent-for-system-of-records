# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-api-key-here

# Model Configuration
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4

# Database
DATABASE_URL=sqlite:///./data/db/app.db
CHROMA_PERSIST_DIR=./data/chroma

# LangWatch — tracing & evaluations
# Get a key at https://app.langwatch.ai/ → Settings → API Keys
# Without a key the agent still runs; spans are just not exported.
LANGWATCH_API_KEY=
# LANGWATCH_ENDPOINT=https://app.langwatch.ai   # override for self-hosted
# LANGWATCH_SERVICE=enterprise-agent-sor
